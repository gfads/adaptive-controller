# ===============================
# 1. Go Builder Stage
# ===============================
FROM golang:1.24.4-bookworm AS go-builder

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates && \
    rm -rf /var/lib/apt/lists/*

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN go build -o sub ./cmd/rabbitmq/sub


# ===============================
# 2. Python Builder Stage
# ===============================
FROM python:3.11-slim-bookworm AS python-builder

COPY ./internal/controllers/neural/requirements.txt .

#*************
RUN pip install --no-cache-dir -r requirements.txt \
    numpy pandas optuna torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cpu
#**************

#RUN pip install --no-cache-dir -r requirements.txt

# Install system libraries required for NumPy and pandas
RUN apt-get update && apt-get install -y --no-install-recommends \
    libgfortran5 libopenblas0 libstdc++6 libgcc-s1 zlib1g libffi8 && \
    rm -rf /var/lib/apt/lists/*

# Install Python packages
#RUN pip install --no-cache-dir numpy pandas optuna
#RUN pip install torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cpu


# ===============================
# 3. Runtime Stage
# ===============================
FROM gcr.io/distroless/base-debian12

WORKDIR /app

# Copy Go binary
COPY --from=go-builder /app/sub /app/sub

# Copy Python runtime + site-packages
COPY --from=python-builder /usr/local/bin/python3 /usr/local/bin/python3
COPY --from=python-builder /usr/local/lib/python3.11 /usr/local/lib/python3.11
COPY --from=python-builder /usr/local/lib/libpython3.11.so.1.0 /usr/local/lib/libpython3.11.so.1.0

# Copy required shared libraries for NumPy and pandas
COPY --from=python-builder /usr/lib/x86_64-linux-gnu/libstdc++.so.6 /usr/lib/x86_64-linux-gnu/libstdc++.so.6
COPY --from=python-builder /usr/lib/x86_64-linux-gnu/libgfortran.so.5 /usr/lib/x86_64-linux-gnu/libgfortran.so.5
COPY --from=python-builder /usr/lib/x86_64-linux-gnu/libopenblas.so.0 /usr/lib/x86_64-linux-gnu/libopenblas.so.0
COPY --from=python-builder /usr/lib/x86_64-linux-gnu/libgcc_s.so.1 /usr/lib/x86_64-linux-gnu/libgcc_s.so.1
COPY --from=python-builder /usr/lib/x86_64-linux-gnu/libz.so.1 /usr/lib/x86_64-linux-gnu/libz.so.1
COPY --from=python-builder /usr/lib/x86_64-linux-gnu/libffi.so.8 /usr/lib/x86_64-linux-gnu/libffi.so.8

# Copy Python scripts and data
COPY ./internal/controllers/neural/adaptiveNN.py /app/adaptiveNN.py
COPY ./internal/controllers/neural/adaptive_pid.py /app/adaptive_pid.py
COPY ./internal/controllers/neural/data-trained.csv /app/data-trained.csv
COPY ./internal/config/config.json /app/config.json

# Environment setup
ENV PATH="/usr/local/bin:$PATH"
ENV PYTHONPATH="/usr/local/lib/python3.11/site-packages"
ENV LD_LIBRARY_PATH="/usr/local/lib:/usr/lib/x86_64-linux-gnu"

# Default command runs Go binary
CMD ["./sub"]
